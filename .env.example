# ─────────────────────────────────────────────
#  JobForge — Environment Variables
#  Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# Get a FREE Gemini API key at: https://aistudio.google.com/apikey
# Free tier: 15 requests/min, 1M tokens/day — no credit card needed
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini model to use (default is best free option)
GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# Optional: Override default paths
# JOBFORGE_DATA_DIR=./data
# JOBFORGE_OUTPUT_DIR=./output
# JOBFORGE_REPORTS_DIR=./reports
